# drama-smith 后端配置示例
# 复制为 .env 后按需修改;所有字段以 DS_ 为前缀(对应 core/config.py Settings)。
# 敏感字段(JWT 密钥等)仅放本地 .env(已 gitignore),切勿提交。

# ---- 运行环境(dev / test / prod)----
DS_ENVIRONMENT=dev

# ---- CORS:逗号分隔的允许来源(开发期放行 Vite 源)----
DS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- 数据库(外部 MySQL):替换 USER / PASSWORD / HOST / 库名 ----
DS_DATABASE_URL=mysql+asyncmy://USER:PASSWORD@HOST:3306/drama_smith?charset=utf8mb4

# 测试库(可选):不设则由 DS_DATABASE_URL 派生 <库名>_test;
# 测试夹具会 CREATE DATABASE 并 alembic upgrade head,每用例 TRUNCATE 隔离。
# DS_TEST_DATABASE_URL=mysql+asyncmy://USER:PASSWORD@HOST:3306/drama_smith_test?charset=utf8mb4

# ---- 鉴权 / 令牌 ----
# 生产务必替换为安全随机值,例如:openssl rand -base64 48
DS_JWT_SECRET=change-me-in-production
# 访问令牌有效期(秒),默认 15 分钟
DS_JWT_ACCESS_TTL_SECONDS=900
# 刷新令牌有效期(天)
DS_REFRESH_TTL_DAYS=7

# ---- BYOK 主密钥(MEK)----
# 信封加密根密钥:每个 API Key 经「DEK 加密、DEK 经 MEK 封存」落库。
# 生成:openssl rand -base64 32  ;务必离线备份!丢失即全部 Key 不可解密。
# 仅放本地 .env(已 gitignore),不入库/日志/OpenAPI。
DS_MEK=

# ---- 登录防爆破 ----
# 连续失败上限
DS_LOGIN_MAX_FAILURES=5
# 锁定时长(分钟)
DS_LOGIN_LOCK_MINUTES=15

# ---- 任务执行器并发上限(M2)----
# 每用户并发任务数(超限排队 pending)、全局协程上限。
# 取值权衡 BYOK 成本:并发越高吞吐越大,但供应商并发/费用同步上升(总纲 §6)。
DS_MAX_TASKS_PER_USER=4
DS_MAX_GLOBAL_WORKERS=8
